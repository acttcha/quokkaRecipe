{
  "expo": {
    "name": "쿼카레시피",
    "slug": "quokka-chef",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/applogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "bundleIdentifier": "com.chasoft.quokkarecipe",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "재료를 촬영해 레시피를 추천받기 위해 카메라가 필요합니다.",
        "NSPhotoLibraryUsageDescription": "갤러리에서 재료 사진을 선택하기 위해 접근이 필요합니다."
      }
    },
    "android": {
      "package": "com.chasoft.quokkarecipe",
      "versionCode": 9,
      "adaptiveIcon": {
        "foregroundImage": "./assets/applogo.png",
        "backgroundColor": "#FAFAF8"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "재료를 촬영해 레시피를 추천받기 위해 카메라가 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "갤러리에서 재료 사진을 선택하기 위해 접근이 필요합니다."
        }
      ],
      "expo-secure-store",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8578688184080776~1793611745",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "expo-localization",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "17c9a7fb-9105-4ad0-8ea8-377637744b4c"
      }
    }
  }
}
